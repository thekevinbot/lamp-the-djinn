# Copy to .env and fill in. .env is gitignored -- it is never committed and I never read it.
#   cp .env.example .env && nvim .env
#
# OpenRouter API key (https://openrouter.ai/keys). Used only by the LiteLLM proxy
# process, which runs on the host outside the cage. The agent never sees it.
OPENROUTER_API_KEY=
